{
    "env": {
        "browser": true,
        "node": true
    },
    "extends": ["airbnb", "prettier"],
    "plugins": ["prettier"],
    "rules": {
        "prettier/prettier": "error",
        "no-unused-vars": "warn",
        "non-console": "off",
        "func-names": "off",
        "no-process-exit": "off",
        "class-methods-use-this": "off",
        "no-param-reassign": "off"
    },
    "parserOptions": {
        "sourceType": "module",
        "ecmaVersion": 2022
    }
}
